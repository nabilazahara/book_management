<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Buku</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#fff7fb;
        }

        .navbar{
            background:#f8c8dc;
        }

        .navbar-brand{
            font-weight:bold;
            color:#b03060 !important;
        }

        .menu-btn{
            color:#b03060 !important;
            font-weight:600;
            margin-left:15px;
            text-decoration:none;
        }

        .title{
            color:#d63384;
            font-weight:bold;
        }

        .subtitle{
            color:#777;
        }

        .book-card{
            border:none;
            border-radius:18px;
            transition:.3s;
        }

        .book-card:hover{
            transform:translateY(-8px);
            box-shadow:0 10px 25px rgba(0,0,0,.15);
        }

        .book-img{
            height:320px;
            object-fit:contain;
            padding:15px;
            background:white;
            border-radius:15px 15px 0 0;
        }

        .btn-pink{
            background:#f48fb1;
            color:white;
            border:none;
        }

        .btn-pink:hover{
            background:#ec6c9d;
            color:white;
        }

        footer{
            color:#888;
            margin-top:50px;
        }
    </style>

</head>

<body>

<nav class="navbar shadow-sm">

<div class="container">

<a href="/" class="navbar-brand">

📚 Book Management System

</a>

<div>

<a href="/" class="menu-btn">

🏠 Home

</a>

<a href="/books" class="menu-btn">

📖 Daftar Buku

</a>

</div>

</div>

</nav>


<div class="container mt-5">

<div class="text-center mb-5">

<h1 class="title">

📚 Daftar Buku

</h1>

<p class="subtitle">

Temukan koleksi buku favorit Anda

</p>

</div>

<div class="row">

<% books.forEach(book=>{ %>

<div class="col-lg-4 col-md-6 mb-4">

<div class="card shadow-sm book-card h-100">

<img src="/images/<%= book.image %>"

class="book-img">

<div class="card-body">

<h5 class="fw-bold text-danger">

<%= book.title %>

</h5>

<p>

<b>Penulis :</b>

<%= book.author %>

</p>

<p>

<b>Tahun :</b>

<%= book.year %>

</p>

<p>

<b>Genre :</b>

<%= book.genre %>

</p>

</div>

<div class="card-footer bg-white border-0">

<a href="/books/<%= book.id %>"

class="btn btn-pink w-100">

Lihat Detail

</a>

</div>

</div>

</div>

<% }) %>

</div>

<div class="text-center mt-4">

<a href="/" class="btn btn-outline-secondary">

← Kembali ke Home

</a>

</div>

<footer class="text-center">

<hr>

<p>

© 2026 Book Management System

</p>

</footer>

</div>

</body>

</html>