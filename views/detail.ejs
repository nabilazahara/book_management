<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= book.title %></title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{

background:#fff7fb;

}

.navbar{

background:#f8c8dc;

}

.navbar-brand{

color:#b03060 !important;

font-weight:bold;

}

.book-card{

border:none;

border-radius:20px;

}

.book-img{

height:550px;

object-fit:contain;

padding:20px;

background:white;

}

.title{

color:#d63384;

font-weight:bold;

}

.btn-pink{

background:#f48fb1;

color:white;

border:none;

}

.btn-pink:hover{

background:#ec6c9d;

color:white;

}

</style>

</head>

<body>

<nav class="navbar shadow-sm">

<div class="container">

<a href="/" class="navbar-brand">

📚 Book Management System

</a>

<div>

<a href="/" class="btn btn-light me-2">

🏠 Home

</a>

<a href="/books" class="btn btn-outline-dark">

📖 Daftar Buku

</a>

</div>

</div>

</nav>

<div class="container mt-5">

<div class="card shadow-lg book-card">

<div class="row">

<div class="col-md-4">

<img src="/images/<%= book.image %>"

class="book-img w-100">

</div>

<div class="col-md-8">

<div class="card-body">

<h1 class="title">

<%= book.title %>

</h1>

<hr>

<p><b>Penulis :</b> <%= book.author %></p>

<p><b>Tahun :</b> <%= book.year %></p>

<p><b>Genre :</b> <%= book.genre %></p>

<p><b>Deskripsi :</b></p>

<p>

<%= book.description %>

</p>

<br>

<a href="/books"

class="btn btn-pink">

← Kembali ke Daftar Buku

</a>

</div>

</div>

</div>

</div>

</div>

</body>

</html>